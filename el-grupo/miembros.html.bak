<script>
// ── Modal ──
const cards=[...document.querySelectorAll('.card')];
let cur=0;
const ov=document.getElementById('ov');
const mphImg=document.getElementById('mph-img');
const mbadge=document.getElementById('mbadge');
const mname=document.getElementById('mname');
const muni=document.getElementById('muni');
const memail=document.getElementById('memail');
const memailA=document.getElementById('memail-a');
const morcid=document.getElementById('morcid');
const morcidA=document.getElementById('morcid-a');
const mcontact=document.getElementById('mcontact');
const mcontactEmailEl=document.getElementById('mcontact-email');
const mcontactEmailA=document.getElementById('mcontact-email-a');
const mcontactOrcidEl=document.getElementById('mcontact-orcid');
const mcontactOrcidA=document.getElementById('mcontact-orcid-a');
const mbio=document.getElementById('mbio');
const mcounter=document.getElementById('mcounter');
const mprev=document.getElementById('mprev');
const mnext=document.getElementById('mnext');
const mscroll=document.querySelector('.mscroll');

function load(i){
  const d=cards[i].dataset;
  mphImg.src=d.photo||'';
  mphImg.alt=d.name||'';
  mbadge.textContent=d.role||'';
  mname.textContent=d.name||'';
  muni.textContent=(d.uni&&d.uni!=='–')?d.uni:'';
  mbio.innerHTML=d.bio||'';
  mcounter.textContent=(i+1)+' / '+cards.length;
  const email=d.email?d.email.trim():'';
  const orcid=d.orcid?d.orcid.trim().replace(/^orcid\s*/i,''):'';

  if(email){memailA.href='mailto:'+email;memailA.textContent=email;memail.style.display='flex';}
  else{memail.style.display='none';}
  if(orcid){const ou='https://orcid.org/'+orcid;morcidA.href=ou;morcidA.textContent=orcid;morcid.style.display='flex';}
  else{morcid.style.display='none';}
  if(email){mcontactEmailA.href='mailto:'+email;mcontactEmailA.textContent=email;mcontactEmailEl.style.display='flex';}
  else{mcontactEmailEl.style.display='none';}
  if(orcid){const ou2='https://orcid.org/'+orcid;mcontactOrcidA.href=ou2;mcontactOrcidA.textContent=orcid;mcontactOrcidEl.style.display='flex';}
  else{mcontactOrcidEl.style.display='none';}
  mcontact.classList.toggle('has-data', !!(email||orcid));
  mprev.disabled=(i===0);
  mnext.disabled=(i===cards.length-1);
  mscroll.scrollTop=0;
}

function open(i){
  cur=i;load(cur);
  ov.classList.add('on');
  document.body.classList.add('locked');
  setTimeout(()=>document.getElementById('mclose').focus(),320);
}
function close(){
  ov.classList.remove('on');
  document.body.classList.remove('locked');
}

cards.forEach((c,i)=>{
  c.addEventListener('click',()=>open(i));
  c.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();open(i);}});
});
mprev.addEventListener('click',()=>{if(cur>0){cur--;load(cur);}});
mnext.addEventListener('click',()=>{if(cur<cards.length-1){cur++;load(cur);}});
document.getElementById('mclose').addEventListener('click',close);
ov.addEventListener('click',e=>{if(e.target===ov)close();});
document.addEventListener('keydown',e=>{
  if(!ov.classList.contains('on'))return;
  if(e.key==='Escape')close();
  if(e.key==='ArrowRight'&&cur<cards.length-1){cur++;load(cur);}
  if(e.key==='ArrowLeft'&&cur>0){cur--;load(cur);}
});
</script>
  <script>
    /* ---- Page reveal animations ---- */
    (function () {
      if (!('IntersectionObserver' in window)) return;
      var els = document.querySelectorAll('.card, .sidebar-card, .founder-card, .news-card, .video-card, .congress-card, .funders, .inline-figure, .inline-figure-left');
      if (!els.length) return;
      els.forEach(function (el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
      });
      var obs = new IntersectionObserver(function (entries) {
        var visible = entries.filter(function (e) { return e.isIntersecting; });
        visible.forEach(function (e, i) {
          e.target.style.transition = 'opacity 0.5s ease-out ' + (i * 0.07) + 's, transform 0.5s ease-out ' + (i * 0.07) + 's';
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          obs.unobserve(e.target);
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { obs.observe(el); });
    })();
  </script>
  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menuToggle');
    const nav = document.getElementById('mainNav');
    toggle.addEventListener('click', () => { nav.classList.toggle('open'); document.body.classList.toggle('menu-open', nav.classList.contains('open')); });

    // Accordion dropdowns on mobile
    document.querySelectorAll('.has-dropdown > span').forEach(function(el) {
      el.addEventListener('click', function() {
        if (window.innerWidth <= 1100) {
          el.parentElement.classList.toggle('open');
        }
      });
    });
  </script>
  <script>var SITE_ROOT='../';</script>
  <script src="../search-data.js"></script>
<script src="../site-search.js"></script>
  <script>
    // Modo noche
    (function() {
      var toggle = document.getElementById('themeToggle');
      var saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
        toggle.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
      }
      toggle.addEventListener('click', function() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
          toggle.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
          } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
          toggle.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
        }
      });
    })();
  </script>
</body>
</html>
